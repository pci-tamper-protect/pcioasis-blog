        <mxCell id="p3-enc-row1" value="a8f3 2c1b 9e47 d2a5  c81f 3b9e 7a4d 2f81" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#88cc88;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="558" y="136" width="580" height="22" as="geometry" />
