            <mxPoint x="498" y="400" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4-arr-to-zk1-lbl" value="value" style="text;html=1;align=center;fontSize=9;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="438" y="386" width="60" height="16" as="geometry" />
        </mxCell>
        <mxCell id="p4-arr-to-zk2" value="" style="endArrow=open;endFill=0;html=1;strokeColor=#9999ff;animated=1;flow=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="674" y="282" as="sourcePoint" />
            <mxPoint x="643" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4-arr-to-zk2-lbl" value="predicate" style="text;html=1;align=center;fontSize=9;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="640" y="295" width="70" height="16" as="geometry" />
