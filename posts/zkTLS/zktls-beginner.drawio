        <mxCell id="p4-proof-out" value="✅  zk_proof output&lt;br/&gt;&lt;br/&gt;&lt;tt&gt;[0xab, 0xf2, 0x3c, ...]&lt;/tt&gt;&lt;br/&gt;~200–500 bytes&lt;br/&gt;&lt;br/&gt;Sent to apartment backend.&lt;br/&gt;Contains NO salary data." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="498" y="686" width="290" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p4-key-msg" value="&lt;b&gt;Key point for beginners:&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;$82,500 is extracted, used in the proof calculation,&lt;br/&gt;and then discarded — all inside the browser tab.&lt;br/&gt;&lt;br/&gt;The apartment backend never sees it.&lt;br/&gt;The Attestor never sees it.&lt;br/&gt;Only Jordan sees it (in the ADP modal)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
