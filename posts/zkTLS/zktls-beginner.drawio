        <mxCell id="p3-block2-row2" value="2e8a 4c7b 9f3d 1a5e  8b2c 6f4a 7d9e 3c1b" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#ffdd88;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="558" y="382" width="580" height="22" as="geometry" />
        </mxCell>
        <mxCell id="p3-block2-label" value="COMMITTED BLOCK #2" style="text;html=1;align=right;fontSize=10;fontStyle=1;strokeColor=none;fillColor=none;fontColor=#ffcc00;" vertex="1" parent="1">
          <mxGeometry x="558" y="406" width="585" height="16" as="geometry" />
        </mxCell>
        <mxCell id="p3-enc-row9" value="5a1c 8f3e 2b9d 4c7a  1e6b 9f4c 3a8d 7e2b" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#88cc88;fontFamily=Courier New;" vertex="1" parent="1">
