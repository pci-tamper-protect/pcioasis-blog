        <mxCell id="p2-row6v" value="$27,040" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="310" y="566" width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="p2-modal-note" value="&lt;i&gt;Modal popup — running inside apartments.com — Jordan never left the apartment site&lt;/i&gt;" style="text;html=1;align=center;fontSize=10;strokeColor=none;fillColor=none;fontColor=#777777;" vertex="1" parent="1">
          <mxGeometry x="90" y="640" width="528" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p2-modal-close" value="&lt;font style=&#39;font-size:11px&#39;&gt;Reclaim SDK will now prove this data without sharing it&lt;/font&gt;" style="text;html=1;align=center;fontSize=11;strokeColor=#82b366;fillColor=#d5e8d4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="662" width="528" height="22" as="geometry" />
        </mxCell>
        <mxCell id="p2-ann1" value="&lt;b&gt;This highlighted row is the only field&lt;br/&gt;the ZK proof touches.&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;The proof will confirm:&lt;br/&gt;   82,500 &gt;= 75,000  →  TRUE&lt;br/&gt;&lt;br/&gt;The number $82,500 itself is&lt;br/&gt;never sent to the apartment site." style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="400" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p2-ann1-arr" value="" style="endArrow=open;endFill=0;html=1;strokeColor=#82b366;animated=1;flow=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="483" as="sourcePoint" />
            <mxPoint x="612" y="483" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-ann2" value="&lt;b&gt;Everything else stays private.&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Jordan&#39;s name, employer,&lt;br/&gt;tax, YTD — none of this&lt;br/&gt;appears in the proof." style="shape=callout;whiteSpace=wrap;html=1;fillColor=#ffe9e9;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="620" width="260" height="130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p3" name="3 — Attestor&#39;s View">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3-title" value="Detail 3 — What the Attestor Sees: Encrypted TLS Stream" style="text;html=1;align=center;fontSize=18;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="18" width="1000" height="32" as="geometry" />
        </mxCell>
        <mxCell id="p3-sub" value="The Attestor routes traffic and records commitments — but cannot read the salary. ADP has no idea the Attestor is in the middle." style="text;html=1;align=center;fontSize=12;fontStyle=2;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="46" width="1000" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p3-left-title" value="What ADP sent (decrypted — for illustration only)" style="text;html=1;align=center;fontSize=13;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="440" height="24" as="geometry" />
        </mxCell>
        <mxCell id="p3-left-sub" value="(Only Jordan&#39;s browser can see this — using the session key)" style="text;html=1;align=center;fontSize=10;fontStyle=2;strokeColor=none;fillColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="440" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p3-clear-bg" value="" style="rounded=1;fillColor=#f9fff9;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="124" width="440" height="480" as="geometry" />
        </mxCell>
        <mxCell id="p3-clear-text" value="HTTP/1.1 200 OK&#xa;Content-Type: text/html&#xa;&#xa;&lt;html&gt;&#xa;&lt;div class=&quot;ytd-summary&quot;&gt;&#xa;  Employee:      Jordan Smith&#xa;  Employer:      Acme Corp&#xa;  Pay Period:    Jan-Dec 2025&#xa;&#xa;  Annual Salary: $82,500&#xa;&#xa;  YTD Gross:     $41,250&#xa;  Federal Tax:   $14,210&#xa;  Net Pay YTD:   $27,040&#xa;&lt;/div&gt;&#xa;&lt;/html&gt;" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontFamily=Courier New;whiteSpace=pre;" vertex="1" parent="1">
          <mxGeometry x="56" y="136" width="408" height="320" as="geometry" />
        </mxCell>
        <mxCell id="p3-clear-hl" value="" style="rounded=0;fillColor=#ffff88;strokeColor=#e6b800;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="56" y="288" width="408" height="22" as="geometry" />
        </mxCell>
        <mxCell id="p3-clear-arrow" value="regex matches here" style="text;html=1;align=left;fontSize=10;fontStyle=1;strokeColor=none;fillColor=none;fontColor=#cc8800;" vertex="1" parent="1">
          <mxGeometry x="56" y="312" width="200" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p3-clear-note" value="Jordan can see all this data in the ADP modal.&#xa;The Reclaim SDK uses the session key (which&#xa;only Jordan has) to decrypt it for the ZK proof.&#xa;The session key never leaves the browser." style="text;html=0;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;whiteSpace=pre;" vertex="1" parent="1">
          <mxGeometry x="56" y="466" width="408" height="96" as="geometry" />
        </mxCell>
        <mxCell id="p3-right-title" value="What the Attestor actually sees (TLS ciphertext)" style="text;html=1;align=center;fontSize=13;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="620" height="24" as="geometry" />
        </mxCell>
        <mxCell id="p3-right-sub" value="(AES-GCM encrypted — Attestor cannot read any of this)" style="text;html=1;align=center;fontSize=10;fontStyle=2;strokeColor=none;fillColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="540" y="100" width="620" height="18" as="geometry" />
