        <mxCell id="p3-enc-row10" value="7c4a 1f8e 3d9b 6c2f  4b8a 1e5c 9d3f 2a7b" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#88cc88;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="558" y="452" width="580" height="22" as="geometry" />
        </mxCell>
        <mxCell id="p3-enc-row11" value="9e2c 4f7a 1b8d 5c3e  6f1a 8b4d 2c9e 7a5f" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#88cc88;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="558" y="476" width="580" height="22" as="geometry" />
        </mxCell>
        <mxCell id="p3-enc-row12" value="3b6e 9c1f 4a8d 2e7b  5f3c 1a9e 8b4d 6c2f" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#88cc88;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="558" y="500" width="580" height="22" as="geometry" />
        </mxCell>
        <mxCell id="p3-attestor-msg" value="ATTESTOR:  I see byte streams.&#xa;           I route them and record which&#xa;           blocks were committed.&#xa;           I cannot read Annual Salary." style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#ff8888;fontFamily=Courier New;whiteSpace=pre;" vertex="1" parent="1">
          <mxGeometry x="558" y="534" width="580" height="62" as="geometry" />
        </mxCell>
        <mxCell id="p3-ann1" value="&lt;b&gt;Committed blocks&lt;/b&gt; are the TLS record chunks&lt;br/&gt;that the Attestor records a &lt;b&gt;cryptographic hash&lt;/b&gt; of&lt;br/&gt;and co-signs with its private key.&lt;br/&gt;&lt;br/&gt;These blocks correspond to the ADP response&lt;br/&gt;region containing &quot;Annual Salary: $82,500&quot;.&lt;br/&gt;&lt;br/&gt;The Attestor doesn&#39;t know that — it just sees bytes." style="shape=callout;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="616" width="380" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p3-ann2" value="&lt;b&gt;Jordan&#39;s browser&lt;/b&gt; uses the committed&lt;br/&gt;blocks + the session key to run the ZK proof.&lt;br/&gt;&lt;br/&gt;The session key decrypts the committed blocks.&lt;br/&gt;The ZK prover checks the salary predicate.&lt;br/&gt;&lt;br/&gt;→ See Detail 4 for the browser ZK proof." style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="616" width="340" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p4" name="4 — Browser ZK Proof">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4-title" value="Detail 4 — Inside the Browser: ZK Proof Generation" style="text;html=1;align=center;fontSize=18;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="18" width="900" height="32" as="geometry" />
        </mxCell>
        <mxCell id="p4-sub" value="All of this runs in Jordan&#39;s browser using WebAssembly — the salary value is processed locally and then discarded" style="text;html=1;align=center;fontSize=12;fontStyle=2;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="46" width="900" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p4-browser-outer" value="" style="rounded=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="40" y="78" width="860" height="660" as="geometry" />
        </mxCell>
        <mxCell id="p4-browser-bar" value="⬤  ⬤  ⬤      apartments.com/apply  —  [reclaim-sdk.js running]" style="fillColor=#4a4a4a;strokeColor=none;fontColor=#cccccc;fontSize=11;align=left;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="78" width="860" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p4-browser-inner" value="" style="fillColor=#ffffff;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="108" width="860" height="630" as="geometry" />
        </mxCell>
        <mxCell id="p4-inp-title" value="INPUTS (available in browser memory)" style="text;html=1;align=center;fontSize=12;fontStyle=1;strokeColor=none;fillColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="56" y="116" width="480" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p4-sk-box" value="🔑  session_key&lt;br/&gt;&lt;br/&gt;&lt;tt&gt;3a9f2cb1e0d47f8a...b4e1d208&lt;/tt&gt;&lt;br/&gt;&lt;br/&gt;32 bytes — TLS shared secret&lt;br/&gt;Derived during handshake.&lt;br/&gt;&lt;b&gt;Never sent anywhere.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="56" y="142" width="220" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p4-er-box" value="🔒  enc_resp (committed blocks)&lt;br/&gt;&lt;br/&gt;&lt;tt&gt;f2a8 b3c9 4d1e 7f3a...&lt;br/&gt;3f7e 9c2a 5d1b 8e4f...&lt;/tt&gt;&lt;br/&gt;&lt;br/&gt;Encrypted TLS bytes from ADP.&lt;br/&gt;Attestor co-signed these blocks." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="142" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p4-pred-box" value="📋  predicate&lt;br/&gt;&lt;br/&gt;&lt;tt&gt;annual_salary &gt;= 75000&lt;/tt&gt;&lt;br/&gt;&lt;br/&gt;Set by apartment site when&lt;br/&gt;initializing the SDK." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="564" y="142" width="220" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p4-arr1" value="" style="endArrow=open;endFill=0;html=1;strokeColor=#555555;animated=1;flow=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="166" y="282" as="sourcePoint" />
            <mxPoint x="166" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4-arr2" value="" style="endArrow=open;endFill=0;html=1;strokeColor=#555555;animated=1;flow=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="282" as="sourcePoint" />
            <mxPoint x="420" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4-arr3" value="" style="endArrow=open;endFill=0;html=1;strokeColor=#555555;animated=1;flow=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="674" y="282" as="sourcePoint" />
            <mxPoint x="674" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4-step1" value="&lt;b&gt;Step 1: Decrypt committed blocks&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;AES-256-GCM decrypt using session_key:&lt;br/&gt;&lt;br/&gt;&lt;tt&gt;plaintext = AES.decrypt(enc_resp, session_key)&lt;/tt&gt;&lt;br/&gt;&lt;br/&gt;Result: the HTML fragment containing&lt;br/&gt;&lt;b&gt;&quot;Annual Salary: $82,500&quot;&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9ffe9;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="56" y="320" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p4-arr4" value="" style="endArrow=open;endFill=0;html=1;strokeColor=#555555;animated=1;flow=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="246" y="480" as="sourcePoint" />
            <mxPoint x="246" y="518" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4-step2" value="&lt;b&gt;Step 2: Extract value with regex&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;tt&gt;/Annual Salary.*?\$([0-9,]+)/&lt;/tt&gt;&lt;br/&gt;&lt;br/&gt;Match: &quot;Annual Salary: $82,500&quot;&lt;br/&gt;Captured: &quot;82,500&quot; → integer &lt;b&gt;82500&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9ffe9;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="56" y="518" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p4-arr5" value="" style="endArrow=open;endFill=0;html=1;strokeColor=#555555;animated=1;flow=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="246" y="648" as="sourcePoint" />
            <mxPoint x="246" y="686" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4-step3" value="&lt;b&gt;Step 3: Check predicate&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;tt&gt;82500 &gt;= 75000  →  TRUE&lt;/tt&gt;&lt;br/&gt;&lt;br/&gt;This boolean is what gets proven." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9ffe9;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="56" y="686" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p4-zkbox" value="⚙️  ZK Prover (Groth16 / PLONK)&lt;br/&gt;&lt;b&gt;WebAssembly — runs in browser tab&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Inputs:  extracted value (82500)&lt;br/&gt;         predicate (x &gt;= 75000)&lt;br/&gt;         commitment (from Attestor)&lt;br/&gt;&lt;br/&gt;Output: cryptographic proof&lt;br/&gt;that the predicate holds,&lt;br/&gt;without revealing 82500.&lt;br/&gt;&lt;br/&gt;Duration: 3–15 seconds&lt;br/&gt;CPU-intensive — WASM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#9999ff;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="498" y="320" width="290" height="310" as="geometry" />
        </mxCell>
