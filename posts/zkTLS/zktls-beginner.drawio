        <mxCell id="p3-enc-row2" value="3c9a 5f2e b7d1 8c4a  2b7f 4e9c 1a3d 5c14" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#88cc88;fontFamily=Courier New;" vertex="1" parent="1">
