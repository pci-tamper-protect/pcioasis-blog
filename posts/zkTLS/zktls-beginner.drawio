        <mxCell id="p3-enc-row8" value="6d3a 8f1c 2e9b 4a7f  5c1d 9e3b 7a4f 2c8d" style="text;html=0;align=left;fontSize=12;strokeColor=none;fillColor=none;fontColor=#88cc88;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="558" y="330" width="580" height="22" as="geometry" />
