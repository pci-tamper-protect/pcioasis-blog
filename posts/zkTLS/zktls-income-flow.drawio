      <mxGeometry x="340" y="466" width="185" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="s8-loc" value="&lt;i&gt;Browser: reclaim-sdk.js&lt;/i&gt;" style="text;html=1;align=left;fontSize=9;strokeColor=#82b366;fillColor=#f9ffe9;rounded=1;" vertex="1" parent="1">
