    </mxCell>

    <mxCell id="s10" value="⑩ enc_resp (pay statement HTML, AES-encrypted)" style="endArrow=open;endFill=0;html=1;fontSize=9;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="975" y="558" as="sourcePoint"/>
        <mxPoint x="760" y="558" as="targetPoint"/>
      </mxGeometry>
